cat << 'EOF' > .gitignore
# Archivos compilados de Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# Entornos virtuales
.venv/
venv/
ENV/

# Variables de entorno
.env

# Logs
*.log
logs/

# Testing
.pytest_cache/

# Configuración de IDEs y SO
.vscode/
.idea/
.DS_Store

# Build y distribución
build/
dist/
*.egg-info/

# Específico del proyecto
vectorstore/

# Scripts específicos (revisar si deben ignorarse)
dependencies.sh
verify_installation.py
EOF
